generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}


// ===== car.prisma =====

model Car {
  id BigInt @id @default(autoincrement())
}


// ===== company.prisma =====

model Company {
  id BigInt @id @default(autoincrement())
  company_code String @db.VarChar(50) @unique
  name String @db.VarChar(50)
  created_at   DateTime @default(now()) @db.Timestamp()
  updated_at    DateTime @updatedAt @db.Timestamp()

  Customers Customers[]
}


// ===== contract.prisma =====

model Contract {
  id BigInt @id @default(autoincrement())
}


// ===== contract_document.prisma =====

model ContractDocument {
  id BigInt @id @default(autoincrement())
}


// ===== customer.prisma =====

model Customers {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(50)
  gender       String   @db.Char(6)
  phone_number String   @unique @db.VarChar(13)
  age_group    String?  @db.Char(2)
  region       String?  @db.Char(4)
  email        String   @unique @db.VarChar(50)
  memo         String?
  created_at   DateTime @default(now()) @db.Timestamp()
  updated_at    DateTime @updatedAt @db.Timestamp()
  companies    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  company_id   BigInt
}


// ===== file.prisma =====

model File {
  id BigInt @id @default(autoincrement())
}


// ===== image.prisma =====

model Image {
  id BigInt @id @default(autoincrement())
}


// ===== meeting.prisma =====

model Meeting {
  id BigInt @id @default(autoincrement())
}


// ===== refresh_token.prisma =====

model RefreshToken {
  id BigInt @id @default(autoincrement())
}


// ===== user.prisma =====

model User {
  id BigInt @id @default(autoincrement())
}
